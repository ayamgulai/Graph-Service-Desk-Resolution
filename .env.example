# ============================================================
# IT Service Desk Knowledge Graph — Environment Configuration
# ============================================================

# --- LLM Provider Toggle ---
# Choose your LLM provider: "openrouter", "openai", "gemini", "anthropic", "ollama", "lmstudio"
LLM_PROVIDER=openrouter

# --- OpenRouter Settings (used when LLM_PROVIDER=openrouter) ---
OPENROUTER_API_KEY=sk-or-v1-...your-openrouter-key...
OPENROUTER_MODEL_NAME=google/gemini-2.0-flash-exp
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_APP_NAME=IT-ServiceDesk-KnowledgeGraph

# --- OpenAI Settings (used when LLM_PROVIDER=openai) ---
OPENAI_API_KEY=sk-...your-openai-api-key...
OPENAI_MODEL_NAME=gpt-4o

# --- Google Gemini Settings (used when LLM_PROVIDER=gemini) ---
GOOGLE_API_KEY=your-google-gemini-api-key
GEMINI_MODEL_NAME=gemini-2.0-flash

# --- Neo4j AuraDB / Local Settings ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password

# --- Pipeline Settings ---
# Number of CSV rows to process (keep low for testing)
SAMPLE_SIZE=20
